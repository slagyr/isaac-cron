{:id :isaac.cron,
 :version "0.1.2",
 :builtin? true,
 :factory isaac.cron.module/create-module,
 :isaac.config/schema
 {:cron
  {:entity-dir "cron",
   :frontmatter? true,
   :merge-root-entity? true,
   :companion {:field :prompt, :mode :required},
   :schema
   {:name "cron table",
    :type :map,
    :description
    "Cron job configurations (map of job name -> cron job config)",
    :key-spec {:type :string},
    :value-spec
    {:name :cron-job,
     :type :map,
     :description "Cron job configuration",
     :schema
     {:crew
      {:type :id,
       :description "Crew id to run the job as",
       :validations [:crew-exists?]},
      :expr {:type :string, :description "5-field cron expression"},
      :prompt
      {:type :string,
       :description "Prompt sent when the cron job fires"},
      :comm
      {:type :string,
       :description "Comm to deliver the job's response through (optional)",
       :validations [[:nil-or? [:registered-in? :isaac.server/comm [:comms]]]]},
      :to
      {:type :string,
       :description "Recipient on the target comm (required when :comm is set)"},
      ;; Session frequencies (selection + per-turn override). Mirrors
      ;; isaac.session.frequencies/frequencies-schema so a cron job picks which
      ;; session its scheduled prompt runs on (resume/most-recent/always-new)
      ;; and may override crew/model/effort/context-mode for the turn.
      :session
      {:type :seq,
       :description "Explicit session id(s); first is used",
       :spec {:type :string}},
      :session-tags
      {:type :seq,
       :description "Tags the target session must carry (AND)",
       :spec {:type :keyword}},
      :reach
      {:type :keyword,
       :description "How many sessions to target (:one for cron)",
       :validations [[:one-of? :one :all]]},
      :prefer
      {:type :keyword,
       :description "Multi-match tiebreak when :reach is :one",
       :validations [[:one-of? :recent :oldest]]},
      :create
      {:type :keyword,
       :description "Create policy: :never, :if-missing, or :always (cron default :always)",
       :validations [[:one-of? :never :if-missing :always]]},
      :with-crew
      {:type :string, :description "Override crew for the scheduled turn"},
      :with-model
      {:type :string, :description "Override model for the scheduled turn"},
      :with-effort
      {:type :int, :description "Override effort for the scheduled turn"},
      :with-context-mode
      {:type :keyword, :description "Override context mode for the scheduled turn"}}}}}}}}
